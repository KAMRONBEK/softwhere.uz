{
  "name": "softwhere.uz",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:debug": "cross-env NODE_OPTIONS=--inspect next dev",
    "build": "next build",
    "start": "next start",
    "dev:env": "yarn env:pull:development && next dev",
    "dev:production": "yarn env:pull:production && next dev",
    "start:production": "yarn env:pull:production && next start",
    "clean": "rm -rf .next .next/dev",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.{js,jsx,ts,tsx,json,css,scss,md}\"",
    "format:check": "prettier --check .",
    "type-check": "tsc --noEmit",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio",
    "normalize-line-endings": "git add --renormalize .",
    "env:pull:production": "npx vercel env pull .env --environment production --yes",
    "env:pull:development": "npx vercel env pull .env --environment development --yes",
    "env:pull:local:production": "npx vercel env pull .env.local --environment production --yes",
    "mcp": "yarn env:pull:local:production && node scripts/verify-mcp-env.js",
    "mcp:searchconsole": "node scripts/searchconsole-mcp.js",
    "mcp:yandex-webmaster": "node scripts/yandex-webmaster-mcp.js"
  },
  "dependencies": {
    "@neondatabase/auth": "^0.4.2-beta",
    "@neondatabase/serverless": "^1.1.0",
    "@vercel/analytics": "^1.6.1",
    "@vercel/speed-insights": "^1.2.0",
    "aos": "^2.3.4",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.45.2",
    "next": "^16.1.6",
    "next-intl": "4",
    "next-themes": "^0.4.6",
    "openai": "^6.22.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-icons": "^5.5.0",
    "react-international-phone": "^4.2.6",
    "react-markdown": "^10.1.0",
    "react-slick": "^0.30.2",
    "react-toastify": "^10.0.5",
    "react-type-animation": "^3.2.0",
    "rehype-highlight": "^7.0.2",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "sharp": "^0.33.3",
    "slick-carousel": "^1.8.1",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@types/aos": "^3.0.7",
    "@types/node": "^20.17.32",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-slick": "^0.23.13",
    "@types/uuid": "^10.0.0",
    "autoprefixer": "^10.0.1",
    "cross-env": "^10.1.0",
    "dotenv": "^17.3.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "^16.1.6",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-boundaries": "^5.0.1",
    "eslint-plugin-prettier": "^5.4.0",
    "playwright": "^1.58.2",
    "postcss": "^8",
    "prettier": "^3.5.3",
    "tailwindcss": "^3.3.0",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3"
  },
  "packageManager": "yarn@1.22.19+sha512.ff4579ab459bb25aa7c0ff75b62acebe576f6084b36aa842971cf250a5d8c6cd3bc9420b22ce63c7f93a0857bc6ef29291db39c3e7a23aab5adfd5a4dd6c5d71"
}
