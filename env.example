# =============================================================================
# ENVIRONMENT CONFIGURATION EXAMPLE
# =============================================================================
# Copy this file to .env.local and fill in your actual values
# Never commit .env.local to version control

# =============================================================================
# SOFTWHERE.UZ - COMPLETE CREDENTIALS LIST
# =============================================================================

# =============================================================================
# 🔑 REQUIRED CREDENTIALS (CRITICAL)
# =============================================================================

# 1. DATABASE_URL ⚠️ CRITICAL
# Purpose: Neon (serverless Postgres) connection for storing blog posts
# Format: postgresql://user:pass@ep-xxx-pooler.<region>.aws.neon.tech/neondb?sslmode=require
# Where to get: Vercel → Storage → Neon (auto-injected), or neon.tech
# Status: REQUIRED - DB queries fail without this
DATABASE_URL=postgresql://your-user:your-pass@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require

# 2. NEXT_PUBLIC_BASE_URL ⚠️ CRITICAL FOR FIXING FETCH ERRORS
# Purpose: Base URL for internal API calls (fixes your fetch error)
# Development: http://localhost:3000
# Production: https://softwhere.uz
# Status: REQUIRED - This is likely causing your fetch error
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# =============================================================================
# 🔑 TELEGRAM BOT CREDENTIALS (for contact form)
# =============================================================================

# 3. NEXT_PUBLIC_TG_BOT_TOKEN
# Purpose: Telegram bot for contact form notifications
# Format: 1234567890:ABCdefGHIjklMNOpqrSTUvwxYZ
# Where to get: @BotFather on Telegram
# Status: Required for contact form functionality
NEXT_PUBLIC_TG_BOT_TOKEN=your-telegram-bot-token-here

# 4. NEXT_PUBLIC_TG_CHAT_ID
# Purpose: Telegram chat where notifications are sent
# Format: -1234567890 (negative for groups)
# Where to get: Message your bot and check updates
# Status: Required for contact form functionality
NEXT_PUBLIC_TG_CHAT_ID=your-telegram-chat-id-here

# =============================================================================
# 🔑 OPTIONAL API KEYS (for enhanced features)
# =============================================================================

# 5. DEEPSEEK_API_KEY
# Purpose: DeepSeek AI for blog post generation & estimation
# Where to get: https://platform.deepseek.com
# Status: Optional - enables AI blog generation
DEEPSEEK_API_KEY=your-deepseek-api-key-here

# 6. API_SECRET
# Purpose: Securing admin endpoints
# Format: Random secure string
# Status: Optional - adds security to admin operations
API_SECRET=your-random-secret-string-here

# 7. UNSPLASH_ACCESS_KEY
# Purpose: Cover images for AI-generated blog posts
# Where to get: https://unsplash.com/developers
# Status: Optional - blog posts will have no cover images without it
UNSPLASH_ACCESS_KEY=your-unsplash-access-key-here

# =============================================================================
# 🔑 SYSTEM VARIABLES
# =============================================================================

# 8. NODE_ENV
# Purpose: Environment mode
# Values: development, production
# Status: Auto-set by hosting platform
NODE_ENV=development

# 9. WEBSITE_URL
# Purpose: External website references
# Value: https://softwhere.uz/
# Status: Optional
WEBSITE_URL=https://softwhere.uz/

# =============================================================================
# 🚨 TO FIX YOUR FETCH ERROR
# =============================================================================

# Your "fetch failed" error is most likely due to missing NEXT_PUBLIC_BASE_URL
# 
# Quick Fix Steps:
# 1. Copy this file to .env.local
# 2. Set NEXT_PUBLIC_BASE_URL=http://localhost:3000 for development
# 3. Add your Neon DATABASE_URL
# 4. Add Telegram bot credentials for contact form
# 5. Restart your development server
#
# The NEXT_PUBLIC_BASE_URL is the most critical missing piece!

# =============================================================================
# 📋 PRIORITY ORDER FOR SETUP
# =============================================================================

# HIGH PRIORITY (Required for basic functionality):
# ✅ DATABASE_URL
# ✅ NEXT_PUBLIC_BASE_URL
#
# MEDIUM PRIORITY (Required for contact form):
# ✅ NEXT_PUBLIC_TG_BOT_TOKEN
# ✅ NEXT_PUBLIC_TG_CHAT_ID
#
# LOW PRIORITY (Optional features):
# ⭕ DEEPSEEK_API_KEY
# ⭕ API_SECRET
# ⭕ UNSPLASH_ACCESS_KEY

# =============================================================================
# 🔒 SECURITY REMINDERS
# =============================================================================

# - Never commit .env.local to version control
# - Use strong, unique values for API_SECRET
# - Rotate API keys regularly
# - Keep your Telegram bot token secure
# - Use environment-specific values for each deployment
# - DATABASE_URL contains sensitive credentials - keep it secure

# =============================================================================
# DEVELOPMENT NOTES
# =============================================================================

# 1. DATABASE_URL is REQUIRED - DB queries fail without it
# 2. NEXT_PUBLIC_BASE_URL is CRITICAL for API calls to work properly
# 3. For local development, use: NEXT_PUBLIC_BASE_URL=http://localhost:3000
# 4. For production deployment, use your actual domain
# 5. Telegram bot credentials are for contact form notifications
# 6. API keys are optional but enable blog generation features
# 6. API_SECRET adds security to admin operations

# =============================================================================
# TROUBLESHOOTING THE FETCH ERROR
# =============================================================================

# The "fetch failed" error you're experiencing is likely due to missing NEXT_PUBLIC_BASE_URL
# 
# To fix the error:
# 1. Copy this file to .env.local
# 2. Set NEXT_PUBLIC_BASE_URL=http://localhost:3000 for development
# 3. Set NEXT_PUBLIC_BASE_URL=https://softwhere.uz for production
# 4. Add your Neon DATABASE_URL
# 5. Restart your development server

# If you get "fetch failed" or "ECONNREFUSED" errors:
# - Make sure NEXT_PUBLIC_BASE_URL is set correctly
# - For local dev: NEXT_PUBLIC_BASE_URL=http://localhost:3000
# - For production: NEXT_PUBLIC_BASE_URL=https://yourdomain.com

# If the database connection fails:
# - Verify your DATABASE_URL is correct (copy it from the Neon dashboard)
# - Ensure the connection string ends with ?sslmode=require
# - Check the Neon project isn't paused/suspended


