# =============================================================================
# softwhere.uz — environment template
# =============================================================================
# Copy to .env.local and fill in real values.  NEVER commit .env.local.
# This template mirrors what the code actually reads. The full annotated
# catalog (scope, where each var is read, defaults) is in docs/environment.md.
#
# Scope: NEXT_PUBLIC_* are inlined into the browser bundle at build time and are
# PUBLIC. Everything else is server-only — never prefix a secret with NEXT_PUBLIC_.

# -----------------------------------------------------------------------------
# Required
# -----------------------------------------------------------------------------

# Neon (serverless Postgres) connection — the @neondatabase/serverless HTTP
# driver and drizzle-kit both read this. From Vercel → Storage → Neon (auto-
# injected) or neon.tech. DB queries fail without it.
DATABASE_URL=postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require

# Public site origin, no trailing slash. Backs canonical URLs, sitemap/robots,
# and internal fetch targets in scripts. Use http://localhost:3000 for local dev.
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# AI (blog generation + estimator refinement) — set at least one key to enable
# -----------------------------------------------------------------------------
# Provider chain in src/core/ai.ts: primary Kimi K2.6 (Moonshot) → fallback
# DeepSeek V4 Pro. With no key set, AI features are simply disabled.

# Primary: Kimi K2.6 on Moonshot (host https://api.moonshot.ai/v1).
# KIMI_API_KEY is accepted as an alias. From https://platform.moonshot.ai
MOONSHOT_API_KEY=your-moonshot-kimi-api-key
# Fallback: DeepSeek V4 Pro (host https://api.deepseek.com). From https://platform.deepseek.com
DEEPSEEK_API_KEY=your-deepseek-api-key
# Optional per-provider overrides (defaults: kimi-k2.6 / deepseek-v4-pro):
# AI_BASE_URL=   AI_MODEL=   AI_FALLBACK_BASE_URL=   AI_FALLBACK_MODEL=

# -----------------------------------------------------------------------------
# Admin panel auth (Neon Auth) — admin fails closed if unset; public site boots
# -----------------------------------------------------------------------------
# Enable Neon Auth in the Neon Console → Auth, then set the project auth base:
NEON_AUTH_BASE_URL=https://ep-xxx.neonauth.region.aws.neon.tech/neondb
# Session-cookie signing key, min 32 chars.  Generate: openssl rand -base64 32
NEON_AUTH_COOKIE_SECRET=generate-a-long-random-string-min-32-chars
# Bearer token for machine callers (scripts/cron/curl) hitting the admin &
# blog-generation APIs, and for the post-publish ISR cache bust. Any long random string.
API_SECRET=your-random-secret-string

# -----------------------------------------------------------------------------
# Contact form / lead notifications (Telegram) — SERVER-ONLY, never NEXT_PUBLIC_
# -----------------------------------------------------------------------------
# Bot token from @BotFather; chat id from the bot's getUpdates (negative for groups).
TG_BOT_TOKEN=your-telegram-bot-token
TG_CHAT_ID=your-telegram-chat-id

# -----------------------------------------------------------------------------
# Optional feature keys
# -----------------------------------------------------------------------------
# Cover images for AI posts (https://unsplash.com/developers). Without it, posts have no cover.
UNSPLASH_ACCESS_KEY=your-unsplash-access-key
# Currency rates for the estimator (https://www.exchangerate-api.com).
# Without it, the route falls back to the free open.er-api.com endpoint.
EXCHANGERATE_API_KEY=your-exchangerate-api-key
# Blog SEO author name (server; NEXT_PUBLIC_BLOG_AUTHOR is the client fallback).
# BLOG_AUTHOR_NAME=SoftWhere.uz Team

# -----------------------------------------------------------------------------
# Platform-set (do NOT set manually on Vercel / CI)
# -----------------------------------------------------------------------------
# NODE_ENV is set by the host. GITHUB_EVENT_NAME / GITHUB_STEP_SUMMARY are
# injected by GitHub Actions for the generator/audit scripts.
NODE_ENV=development

# -----------------------------------------------------------------------------
# MCP tooling secrets (local only — read by scripts/*-mcp.js, never by the app)
# -----------------------------------------------------------------------------
# Normally pulled via `yarn mcp`. See docs/mcp.md.
# YANDEX_WEBMASTER_TOKEN=
# GSC_SERVICE_ACCOUNT_JSON_BASE64=
# GITHUB_PERSONAL_ACCESS_TOKEN=
