# Telegram Bot (server-side only)
TG_BOT_TOKEN=your_telegram_bot_token
TG_CHAT_ID=your_telegram_chat_id

# DeepSeek API (blog post generation & estimation)
DEEPSEEK_API_KEY=your_deepseek_api_key

# Neon (serverless Postgres) connection string — copy it from the Vercel/Neon
# dashboard. Works with the @neondatabase/serverless HTTP driver.
# Example: postgresql://user:pass@ep-xxx-pooler.<region>.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require

# Secret for authenticating blog generation API and admin routes
API_SECRET=your_api_secret

# Public-facing site URL (no trailing slash for BASE_URL)
WEBSITE_URL=https://softwhere.uz/
NEXT_PUBLIC_BASE_URL=https://softwhere.uz

# Node environment
NODE_ENV=development
