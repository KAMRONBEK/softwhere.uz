# Telegram Bot (server-side only)
TG_BOT_TOKEN=your_telegram_bot_token
TG_CHAT_ID=your_telegram_chat_id

# AI: primary Kimi K2.6 (Moonshot), fallback DeepSeek V4 Pro — set at least one.
# KIMI_API_KEY is an accepted alias for MOONSHOT_API_KEY.
MOONSHOT_API_KEY=your_moonshot_kimi_api_key
DEEPSEEK_API_KEY=your_deepseek_api_key

# Optional feature keys
UNSPLASH_ACCESS_KEY=your_unsplash_access_key      # blog cover images
EXCHANGERATE_API_KEY=your_exchangerate_api_key    # estimator currency rates

# Neon (serverless Postgres) connection string — copy it from the Vercel/Neon
# dashboard. Works with the @neondatabase/serverless HTTP driver.
# Example: postgresql://user:pass@ep-xxx-pooler.<region>.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require

# Neon Auth (admin panel login). Enable Neon Auth in the Neon Console, then:
#  - NEON_AUTH_BASE_URL: your project's auth base, e.g.
#    https://ep-xxx.neonauth.<region>.aws.neon.tech/<db>  (see Console → Auth)
#  - NEON_AUTH_COOKIE_SECRET: signing key for the session cookie, min 32 chars.
#    Generate with:  openssl rand -base64 32
# Admin gate fails closed if unset (public site still boots).
NEON_AUTH_BASE_URL=https://ep-xxx.neonauth.region.aws.neon.tech/neondb
NEON_AUTH_COOKIE_SECRET=generate_a_long_random_string_min_32_chars

# Machine/bearer token for scripts, cron, or curl hitting the admin & blog
# generation APIs (the browser admin panel uses Neon Auth + a session cookie).
API_SECRET=your_api_secret

# Public-facing site URL (no trailing slash)
NEXT_PUBLIC_BASE_URL=https://softwhere.uz

# Node environment
NODE_ENV=development
