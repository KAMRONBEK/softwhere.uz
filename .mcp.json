{
  "mcpServers": {
    "vercel": {
      "type": "http",
      "url": "https://mcp.vercel.com"
    },
    "neon": {
      "type": "http",
      "url": "https://mcp.neon.tech/mcp"
    },
    "context7": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp@latest"
      ],
      "env": {}
    },
    "playwright": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@playwright/mcp@latest"
      ],
      "env": {}
    },
    "searchconsole-mcp": {
      "type": "stdio",
      "command": "node",
      "args": [
        "scripts/searchconsole-mcp.js"
      ],
      "env": {}
    },
    "yandex-webmaster": {
      "type": "stdio",
      "command": "node",
      "args": [
        "scripts/yandex-webmaster-mcp.js"
      ],
      "env": {
        "YANDEX_WEBMASTER_HOST_URL": "https://softwhere.uz"
      }
    }
  }
}