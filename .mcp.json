{
  "mcpServers": {
    "vercel": {
      "type": "http",
      "url": "https://mcp.vercel.com"
    },
    "neon": {
      "type": "http",
      "url": "https://mcp.neon.tech/mcp"
    },
    "context7": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp@latest"
      ],
      "env": {}
    },
    "playwright": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@playwright/mcp@latest"
      ],
      "env": {}
    },
    "github": {
      "type": "stdio",
      "command": "docker",
      "args": [
        "run",
        "-i",
        "--rm",
        "-e",
        "GITHUB_PERSONAL_ACCESS_TOKEN",
        "ghcr.io/github/github-mcp-server"
      ],
      "env": {}
    },
    "searchconsole-mcp": {
      "type": "stdio",
      "command": "yarn",
      "args": [
        "mcp:searchconsole"
      ],
      "env": {}
    },
    "yandex-webmaster": {
      "type": "stdio",
      "command": "yarn",
      "args": [
        "mcp:yandex-webmaster"
      ],
      "env": {
        "YANDEX_WEBMASTER_HOST_URL": "https://softwhere.uz"
      }
    }
  }
}