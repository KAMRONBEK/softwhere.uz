{
  "mcpServers": {
    "vercel": {
      "url": "https://mcp.vercel.com"
    },
    "neon": {
      "url": "https://mcp.neon.tech/mcp"
    },
    "context7": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp@latest"]
    },
    "playwright": {
      "command": "npx",
      "args": ["-y", "@playwright/mcp@latest"]
    },
    "github": {
      "url": "https://api.githubcopilot.com/mcp/"
    },
    "searchconsole-mcp": {
      "type": "stdio",
      "command": "node",
      "args": ["scripts/searchconsole-mcp.js"]
    },
    "yandex-webmaster": {
      "type": "stdio",
      "command": "node",
      "args": ["scripts/yandex-webmaster-mcp.js"],
      "env": {
        "YANDEX_WEBMASTER_HOST_URL": "https://softwhere.uz"
      }
    }
  }
}
